# General
auto-update = off
# TODO:Change based on what operationg system I'm using
command = "/opt/homebrew/bin/zsh"
# Needed to fix weird issue with newlines and Ghostty configuration
# FIXME:Maybe be able to use psvar to get around it, will figure it out later
# Apparently will be fixed in Ghostty 1.3.2, maybe
shell-integration = none

# Appearance
theme = "Atom One Dark"
window-padding-x = 2
window-padding-y = 0

# Font Configurations
font-family = "SauceCodePro Nerd Font"
font-size = 16
font-style = "Medium"
